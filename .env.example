# Database
# Dev (SQLite, zero setup):
DATABASE_URL=sqlite+aiosqlite:///./hotclaw.db
# Prod (PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/hotclaw

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM API
LLM_API_KEY=your-api-key-here
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o-mini

# App
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# Log
LOG_LEVEL=INFO

# Timeouts (seconds)
AGENT_TIMEOUT=120
SKILL_TIMEOUT=60
LLM_TIMEOUT=60
